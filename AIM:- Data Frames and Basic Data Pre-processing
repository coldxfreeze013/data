import pandas as pd
import matplotlib.pyplot as plt
import json

# Read Cardio dataset
df = pd.read_csv(r"C:\Users\Admin\Downloads\CardioGoodFitness.csv")

print(df.head())
print(df.isnull().sum())

df1 = df.dropna()
print(df1.head())
print(df1.isnull().sum())

# Scatter Plot Age vs Fitness
plt.scatter(df['Age'], df['Fitness'])
plt.xlabel("Age")
plt.ylabel("Fitness")
plt.title("Age vs Fitness")
plt.show()

# Sorting
sorted_df = df.sort_values(by='Age', ascending=False)
print(sorted_df)

# Grouping
mcount = df.groupby('MaritalStatus')['MaritalStatus'].count()
print(mcount)

